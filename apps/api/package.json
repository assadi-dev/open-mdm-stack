{
  "name": "mdm-server-api",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Assadi",
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npx tsc && npx tsc-alias",
    "dev": "nodemon",
    "start": "node ./build/main.js",
    "db:create": "npx tsx src/drizzle/create-database.ts",
    "db:generate": "npx drizzle-kit generate",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "db:migrate": "npx drizzle-kit migrate",
    "db:drop": "npx drizzle-kit drop",
    "db:sync": "npm run db:generate && npm run db:migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/core": "^3.974.23",
    "@better-auth/drizzle-adapter": "^1.6.20",
    "better-auth": "^1.6.20",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "livekit-server-sdk": "^2.15.3",
    "morgan": "^1.10.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsyringe": "^4.10.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@aws-sdk/types": "^3.973.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.11",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4"
  }
}