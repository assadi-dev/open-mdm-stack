<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only overlay: marks the build as testOnly so a provisioned Device Owner
  can be removed with `adb shell dpm remove-active-admin ...` (impossible for a
  non-test owner). Never applied to release builds. Install debug with:
      adb install -t -r app-debug.apk
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:testOnly="true"
        tools:ignore="TestOnly" />

</manifest>
